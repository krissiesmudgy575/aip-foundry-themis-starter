{
  "testDir": "tests",
  "generatedTestsDir": "__themis__/tests",
  "testRegex": "\\.(test|spec)\\.(js|jsx|ts|tsx)$",
  "maxWorkers": 4,
  "reporter": "next",
  "environment": "node",
  "tsconfigPath": "tsconfig.json",
  "htmlReportPath": "__themis__/reports/report.html",
  "testIgnore": [
    "^tests/fixtures(?:/|$)"
  ]
}
